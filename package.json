{
  "name": "tesoreria",
  "version": "5.3.4",
  "main": "app.js",
  "description": "Programa para control de prestamos a tesoreria",
  "author": "SebastianGuarnizoCampos",
  "license": "Uso Interno en TuAlianza, Apoyo Laboral, Comercializadora, prohibida su distribucion",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian0912/ControlPrestamos.git"
  },
  "build": {
    "appId": "ControlPrestamosApoyoLaboral",
    "productName": "Gestion Tesoreria",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "dist/tesoreria/**/*",
      "app.js",
      "preload.js",
      {
        "from": "csharp",
        "to": "csharp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "csharp",
        "to": "csharp",
        "filter": [
          "UareUSampleCSharp_CaptureOnly.exe"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.ico"
    },
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "sebastian0912",
        "repo": "ControlPrestamos",
        "releaseType": "release"
      }
    ]
  },
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .\"",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "start:electron": "concurrently \"ng serve --configuration=development --host 0.0.0.0 --port 4400\" \"wait-on http://localhost:4400 && cross-env NODE_ENV=development electron .\"",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "dist": "ng build --configuration production && cross-env NODE_ENV=production electron-builder -p always",
    "dist2": "ng build --configuration production && cross-env NODE_ENV=production electron-builder",
    "dist3": "ng build --configuration production --prerender=false && cross-env NODE_ENV=production electron-builder -p always",
    "serve:ssr:Tesoreria": "node dist/tesoreria/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/cdk": "^19.1.1",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/material": "^19.1.1",
    "@angular/material-moment-adapter": "^19.2.14",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/platform-server": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@angular/ssr": "^19.0.7",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "file-saver": "^2.0.5",
    "fontkit": "^2.0.4",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.2",
    "jszip": "^3.10.1",
    "moment": "^2.30.1",
    "pdf-lib": "^1.17.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.15.10",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.7",
    "@angular/cli": "^19.0.7",
    "@angular/compiler-cli": "^19.0.0",
    "@types/express": "^4.17.17",
    "@types/file-saver": "^2.0.7",
    "@types/fontkit": "^2.0.8",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.1",
    "electron-builder": "^25.1.8",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.6.2",
    "wait-on": "^8.0.2"
  }
}
