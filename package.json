{
  "name": "tesoreria",
  "version": "7.4.9",
  "main": "app.js",
  "description": "Programa para control de prestamos a tesoreria",
  "author": "SebastianGuarnizoCampos",
  "license": "Uso Interno en TuAlianza, Apoyo Laboral, Comercializadora, prohibida su distribucion",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian0912/ControlPrestamos.git"
  },
  "build": {
    "appId": "ControlPrestamosApoyoLaboral",
    "productName": "Gestion Tesoreria",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "dist/tesoreria/**/*",
      "app.js",
      "preload.js",
      {
        "from": "csharp",
        "to": "csharp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "csharp",
        "to": "csharp",
        "filter": [
          "UareUSampleCSharp_CaptureOnly.exe"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.ico"
    },
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "sebastian0912",
        "repo": "ControlPrestamos",
        "releaseType": "release"
      }
    ]
  },
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .\"",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "start:electron": "concurrently \"ng run Tesoreria:serve-electron:development --host 0.0.0.0 --disable-host-check --port 4400\" \"wait-on tcp:4400 && cross-env NODE_ENV=development electron .\"",
    "start:electron:prod": "concurrently \"ng run Tesoreria:serve-electron:production --host 0.0.0.0 --disable-host-check --port 4400\" \"wait-on tcp:4400 && cross-env NODE_ENV=development electron .\"",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "dist": "ng run Tesoreria:build-electron:production --base-href ./ && cross-env NODE_ENV=production electron-builder -p always",
    "dist2": "ng run Tesoreria:build-electron:production --base-href ./ && cross-env NODE_ENV=production electron-builder",
    "dist3": "ng run Tesoreria:build-electron:production && cross-env NODE_ENV=production electron-builder -p always",
    "start:prod": "ng serve --configuration production --host 0.0.0.0 --port 4400",
    "start:prod:ssl": "ng serve --configuration production --host 0.0.0.0 --port 4400 --ssl",
    "build:prod": "ng build --configuration production",
    "serve:dist": "npx http-server dist/tesoreria/browser -o",
    "serve:ssr:Tesoreria": "node dist/tesoreria/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/material-moment-adapter": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "@capacitor/android": "^7.5.0",
    "@capacitor/core": "^7.5.0",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "apexcharts": "^5.10.0",
    "astral-regex": "^2.0.0",
    "echarts": "^6.0.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "file-saver": "^2.0.5",
    "fontkit": "^2.0.4",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "material-icons": "^1.13.14",
    "material-symbols": "^0.40.2",
    "moment": "^2.30.1",
    "ngx-echarts": "^21.0.0",
    "ngx-extended-pdf-viewer": "^25.6.4",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.21",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@capacitor/cli": "^7.5.0",
    "@types/express": "^4.17.25",
    "@types/file-saver": "^2.0.7",
    "@types/fontkit": "^2.0.8",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.19.130",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "wait-on": "^8.0.5"
  }
}
